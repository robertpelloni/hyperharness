{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@hypercode/core": [
        "../core/src/index.ts"
      ],
      "@hypercode/core/*": [
        "../core/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../core/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../core/src/**/*.test.ts",
    "../core/src/**/*.spec.ts",
    "../core/src/**/__tests__/**/*"
  ]
}
