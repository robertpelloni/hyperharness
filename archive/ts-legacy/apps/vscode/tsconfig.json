{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": [
            "ESNext"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "NodeNext",
        "types": [
            "vscode"
        ]
    },
    "include": [
        "src"
    ]
}