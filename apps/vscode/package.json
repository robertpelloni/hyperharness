{
    "name": "borg-vscode-extension",
    "displayName": "Borg Plugin",
    "version": "0.2.0",
    "description": "Connect VS Code to Borg Hub for AI agent orchestration, memory management, and tool invocation",
    "publisher": "borg",
    "engines": {
        "vscode": "^1.85.0"
    },
    "enabledApiProposals": [
        "terminalDataWriteEvent"
    ],
    "categories": [
        "Other",
        "Machine Learning"
    ],
    "keywords": [
        "ai",
        "agents",
        "mcp",
        "orchestration",
        "memory"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": [
            {
                "command": "borg.connect",
                "title": "Borg: Connect to Core"
            },
            {
                "command": "borg.disconnect",
                "title": "Borg: Disconnect from Core"
            },
            {
                "command": "aios.showStatus",
                "title": "AIOS: Show Hub Status"
            },
            {
                "command": "aios.runAgent",
                "title": "AIOS: Run Agent"
            },
            {
                "command": "aios.searchMemory",
                "title": "AIOS: Search Memory"
            },
            {
                "command": "aios.ingestUrl",
                "title": "AIOS: Ingest URL to Knowledge"
            },
            {
                "command": "aios.ingestSelectionToRag",
                "title": "AIOS: Ingest Selection to RAG"
            },
            {
                "command": "aios.rememberSelection",
                "title": "AIOS: Remember Selection"
            },
            {
                "command": "aios.listTools",
                "title": "AIOS: List Tools"
            },
            {
                "command": "aios.invokeTool",
                "title": "AIOS: Invoke Tool"
            },
            {
                "command": "aios.openDashboard",
                "title": "AIOS: Open Dashboard"
            },
            {
                "command": "aios.showLogs",
                "title": "AIOS: Show Logs"
            },
            {
                "command": "aios.startDebate",
                "title": "AIOS: Start Council Debate"
            },
            {
                "command": "aios.viewAnalytics",
                "title": "AIOS: View Supervisor Analytics"
            },
            {
                "command": "aios.listDebateTemplates",
                "title": "AIOS: List Debate Templates"
            },
            {
                "command": "aios.architectMode",
                "title": "AIOS: Architect Mode (Two-Model)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "aiosSidebar",
                    "title": "AIOS",
                    "icon": "resources/aios.svg"
                }
            ]
        },
        "views": {
            "aiosSidebar": [
                {
                    "type": "webview",
                    "id": "aios.dispatchView",
                    "name": "Mini Dashboard"
                }
            ]
        },
        "configuration": {
            "title": "Borg",
            "properties": {
                "borg.coreUrl": {
                    "type": "string",
                    "default": "ws://localhost:3001",
                    "description": "URL of the Borg Core WebSocket server"
                },
                "borg.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API key for authenticated Core access"
                },
                "borg.dashboardUrl": {
                    "type": "string",
                    "default": "http://localhost:3000",
                    "description": "Base URL of the Borg web dashboard used for deep links from the VS Code extension"
                },
                "borg.autoConnect": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically connect to Core on startup"
                }
            }
        },
        "menus": {
            "editor/context": [
                {
                    "command": "aios.ingestSelectionToRag",
                    "when": "editorHasSelection",
                    "group": "aios@1"
                },
                {
                    "command": "aios.rememberSelection",
                    "when": "editorHasSelection",
                    "group": "aios@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint --no-eslintrc --parser @typescript-eslint/parser \"src/**/*.{ts,tsx,js,mjs,cjs}\"",
        "build": "tsup src/extension.ts --format cjs --external vscode",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "20.x",
        "@types/vscode": "^1.85.0",
        "@types/ws": "^8.5.10",
        "@typescript-eslint/eslint-plugin": "^6.13.1",
        "@typescript-eslint/parser": "^6.13.1",
        "eslint": "^8.54.0",
        "tsup": "^8.0.2",
        "typescript": "^5.3.3",
        "vsce": "^2.15.0"
    },
    "dependencies": {
        "ws": "^8.16.0"
    }
}