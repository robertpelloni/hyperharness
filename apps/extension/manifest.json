{
    "manifest_version": 3,
    "name": "borg Bridge",
    "version": "0.1.0",
    "description": "Connects web-based AI agents to your local borg Core.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "history",
        "debugger"
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*"
    ],
    "background": {
        "service_worker": "dist/background.js",
        "scripts": [
            "dist/background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*"
            ],
            "js": [
                "dist/content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}