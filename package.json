{
    "name":  "borg-monorepo",
    "version":  "0.10.0",
    "private":  true,
    "packageManager":  "pnpm@10.28.0",
    "scripts":  {
                    "start":  "node packages/cli/dist/index.js start",
                    "build":  "node scripts/build_all.mjs",
                    "build:workspace":  "node scripts/build_all.mjs --workspace-only",
                    "build:extensions":  "node scripts/build_all.mjs --extensions-only",
                    "dev":  "node scripts/dev_tabby_ready.mjs",
                    "dev:turbo":  "set CI=true\u0026\u0026 set TURBO_DAEMON=false\u0026\u0026 turbo run dev --concurrency 22 --filter=!@borg/cli --filter=!@repo/*",
                    "dev:server":  "set TURBO_DAEMON=false\u0026\u0026 turbo run dev:server --parallel --filter=!@repo/*",
                    "dev:web":  "set TURBO_DAEMON=false\u0026\u0026 turbo run dev --filter @borg/web",
                    "lint":  "pnpm run check:placeholders",
                    "lint:turbo":  "set TURBO_DAEMON=false\u0026\u0026 turbo run lint --output-logs=errors-only",
                    "test":  "set TURBO_DAEMON=false\u0026\u0026 turbo run test",
                    "check:placeholders":  "node scripts/check-placeholder-regressions.mjs",
                    "check:dev-readiness":  "node scripts/verify_dev_readiness.mjs",
                    "check:release-gate":  "node scripts/check_release_gate.mjs",
                    "check:release-gate:ci":  "node scripts/check_release_gate.mjs --skip-readiness --with-turbo-lint",
                    "index:sync":  "node scripts/sync_master_index.mjs",
                    "index:update":  "node scripts/update_ingestion_status.mjs",
                    "submodules:prune-orphans":  "node scripts/prune_orphaned_gitlinks.mjs",
                    "clean":  "set TURBO_DAEMON=false\u0026\u0026 turbo run clean",
                    "typecheck":  "set TURBO_DAEMON=false\u0026\u0026 turbo run typecheck"
                },
    "devDependencies":  {
                            "@rollup/rollup-win32-x64-msvc":  "4.55.1",
                            "@types/node":  "^20.10.0",
                            "@typescript-eslint/eslint-plugin":  "^8.53.0",
                            "@typescript-eslint/parser":  "^8.53.0",
                            "@vitest/coverage-v8":  "^4.0.16",
                            "better-sqlite3":  "^12.6.2",
                            "eslint":  "^8.57.1",
                            "turbo":  "^2.8.3",
                            "typescript":  "^5.3.3",
                            "vitest":  "^4.0.16"
                        },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "better-sqlite3"
                                           ],
                 "overrides":  {
                                   "glob":  "\u003e=10.5.0",
                                   "sharp":  "0.34.5",
                                   "esbuild":  "\u003e=0.25.0",
                                   "qs":  "\u003e=6.14.1",
                                   "@modelcontextprotocol/sdk":  "\u003e=1.25.2",
                                   "@types/react":  "18.3.3",
                                   "@types/react-dom":  "18.3.0"
                               }
             },
    "dependencies":  {
                         "@vscode/ripgrep":  "^1.17.0"
                     }
}
