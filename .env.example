# =============================================================================
# Hypercode -- Root Environment Variables Example
# =============================================================================
# For local development, copy the per-package examples:
#   cp apps/web/.env.example      apps/web/.env.local
#   cp packages/core/.env.example packages/core/.env
#
# For Docker deployments, copy this file to .env and docker compose picks it up.
# =============================================================================

# AI Provider Keys (at least one required; Hypercode skips missing providers gracefully)
# OpenRouter gives access to all major providers via a single key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Individual provider keys (optional when using OpenRouter)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Core server
PORT=3000
LOG_LEVEL=info

# Web dashboard (uncomment if running core on a non-default port or remote host)
# NEXT_PUBLIC_TRPC_URL=http://localhost:3000/trpc
# NEXT_PUBLIC_CORE_SSE_URL=http://localhost:3001

# Optional integrations
# NEXT_PUBLIC_OPEN_WEBUI_URL=http://localhost:8080
# NEXT_PUBLIC_DEER_FLOW_URL=http://localhost:2026
