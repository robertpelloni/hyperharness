{
    "id": "Borg",
    "name": "Borg",
    "version": "0.1.0",
    "description": "AI Orchestration System integration for Zed",
    "repository": "https://github.com/Borg/Borg",
    "authors": ["Borg Team"],
    "lib": {
        "kind": "Rust",
        "version": "0.1.0"
    },
    "slash_commands": [
        {
            "name": "Borg-debate",
            "description": "Start a council debate on the current selection",
            "requires_argument": true,
            "argument_description": "Description of what to debate"
        },
        {
            "name": "Borg-architect",
            "description": "Start an architect mode session",
            "requires_argument": true,
            "argument_description": "Task description for reasoning model"
        },
        {
            "name": "Borg-analytics",
            "description": "View supervisor analytics",
            "requires_argument": false
        },
        {
            "name": "Borg-templates",
            "description": "List available debate templates",
            "requires_argument": false
        }
    ]
}
